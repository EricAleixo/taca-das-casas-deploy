<%= stylesheet_link_tag "alunos", media: "all", "data-turbo-track": "reload" %>

<div class="container magia-bg">

  <h1 class="text-center mb-4 magia-title">
    🧙‍♂️ O Chapéu Seletor está analisando sua mente...
  </h1>

  <p class="text-center magia-subtitle mb-5">
    Responda com sinceridade... suas escolhas revelarão sua verdadeira casa.
  </p>

  <%= form_with url: salvar_respostas_aluno_path(@aluno), method: :post, local: true do |f| %>

    <div class="container">

      <% @questoes.each_with_index do |questao, index| %>

        <div class="card mb-4 magia-card">
          <div class="card-body text-light">

            <h5 class="card-title magia-pergunta">
              ✨ <strong><%= questao.enunciado %></strong>
            </h5>

            <% questao.alternativas.each do |alternativa| %>
              <div class="form-check magia-alternativa">

                <%= radio_button_tag "respostas[#{questao.id}]", alternativa, false,
                  class: "form-check-input magia-radio",
                  id: "alternativa_#{questao.id}_#{alternativa}" %>

                <%= label_tag "alternativa_#{questao.id}_#{alternativa}",
                  "🔮 #{alternativa}",
                  class: "form-check-label" %>

              </div>
            <% end %>

          </div>
        </div>

        <% if index < @questoes.size - 1 %>
          <hr class="my-4 magia-divisor">
        <% end %>

      <% end %>

      <div class="text-center">
        <%= f.submit "🧙‍♂️ Revelar minha casa", class: "btn magia-btn" %>
      </div>

    </div>

  <% end %>

</div>
